    "remote_host": "devmgmt-wsl",
    "project_path": "/home/andy4917/Dev-Management",
    "purpose": [
      "readiness",
      "runtime_checks",
      "config_provenance",
      "score_layer",
      "audit",
      "startup",
      "artifact_hygiene",
      "task_routing"
