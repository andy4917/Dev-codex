    "windows_ssh_config_path": "C:/Users/anise/.ssh/config",
    "require_direct_top_level_host_alias": true,
    "remote_project": "/home/andy4917/Dev-Management",
    "require_remote_project_open_proof": true,
    "user_result_values": [
      "listed + project opened",
      "manual add worked + project opened",
      "manual add failed",
      "project open failed",
      "sign-in blocker"
