      "distribution": "langchain",
      "role": "RAG and external integration library when a repo contract calls for it"
    },
    "langgraph": {
      "distribution": "langgraph",
      "role": "workflow graph and agent orchestration library when a repo contract calls for it"
    },
    "openai-agents": {
      "distribution": "openai-agents",
      "role": "OpenAI Agents Python SDK"
    },
    "mcp": {
      "distribution": "mcp",
      "role": "Python MCP client/server integration support"
    }
  },
  "active_coding_references": {
    "typescript_runtime_schema": "zod",
    "javascript_shell_scripting": "zx_by_google",
    "python_shell_parsing": "stdlib_shlex",
    "javascript_style": "airbnb_javascript_style_guide",
    "python_style": "google_python_style_guide",
    "refactoring_patterns": "refactoring_guru",
    "implementation_idioms": "30_seconds_of_code",
    "external_code_review_reference": "greptile_when_available"
  },
  "code_guardrails": {
    "python": [
      "ruff check ."
    ],
    "javascript_typescript": [
      "biome check ."
    ],
    "zig": [
      "zig fmt --check <zig-files>",
      "zig build test"
    ],
    "guardrail_order": "repo_owned_scripts_first_then_global_fallbacks"
  },
  "windows_native_domain_knowledge": {
    "document": "docs/WINDOWS_NATIVE_DOMAIN_KNOWLEDGE.md",
    "topics": [
      "powershell_7_core_api_aliases_and_objects",
      "unc_paths_and_long_paths",
      "win32_api_and_registry_paths",
      "execution_policy"
    ]
  },
