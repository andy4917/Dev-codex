        "%APPDATA%\\Python\\Python312\\Scripts\\pipx.exe",
        "%APPDATA%\\Python\\Python313\\Scripts\\pipx.exe",
        "%APPDATA%\\Python\\Python314\\Scripts\\pipx.exe",
