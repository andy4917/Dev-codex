    "script_installers": {
      "uv": "curl -LsSf https://astral.sh/uv/install.sh | sh",
      "nvm": "curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash",
      "node_bundle": "export NVM_DIR=\"$HOME/.nvm\" && . \"$NVM_DIR/nvm.sh\" && nvm install --lts && nvm alias default 'lts/*' && corepack enable && corepack prepare pnpm@latest --activate && (command -v yarn >/dev/null 2>&1 || npm install -g yarn)"
