  "subagent_delegation_policy": {
    "modes": [
      "read_only_scouts",
      "bounded_workers",
      "verification_pair",
      "none",
      "main_only"
    ],
    "active_modes": [
      "read_only_scouts",
      "bounded_workers",
      "verification_pair"
    ],
    "trigger_classes": [
      "broad_multi_surface_audit",
      "global_cleanup",
      "dirty_closeout",
      "policy_checker_change",
      "l2_plus_verification",
      "explicit_exhaustive_file_or_folder_review"
    ],
    "waiver_reasons": [
      "critical_path_live_restart",
      "narrow_leaf_change",
      "tool_unavailable",
      "no_parallelizable_sidecar",
      "plan_mode_read_only"
    ],
    "max_subagents": 2,
    "decision_artifact": ".agent-runs/<run_id>/DELEGATION_DECISION.json",
    "active_artifacts": [
      "DELEGATION_PLAN.json",
      "SUBAGENT_TASKS.json",
      "SUBAGENT_RESULTS.json",
      "INTEGRATION_DECISION_LOG.json",
      "DELEGATION_LEDGER.json"
    ],
    "missing_decision_status": "BLOCKED",
    "subagent_tool_gap_requires_fallback": true
  },
  "vibe_coding_standard": {
    "exploration_required": true,
    "artifact_required": true,
    "clean_context_execution_required": true,
    "three_test_gate_required": true,
    "trunk_branch_leaf_required": true,
    "artifact_fields": [
      "Essence",
      "Impact Map",
      "Constraints",
      "Evidence used",
      "Tests",
      "Rollback/cleanup plan",
      "WARN/BLOCKED disposition"
    ],
    "verification_gates": [
      "Happy Path",
      "Error Case A",
      "Error Case B",
      "Touched code path executed with all touched functions exercised directly when practical",
      "C:\\Users\\anise\\code\\.scratch\\Dev-Management scratch harness may copy relevant production code/config/data to observe actual production behavior",
      "repo lint/test/typecheck/build/preflight when available"
    ]
  },
  "touched_code_runtime_verification": {
    "required": true,
    "exact_code_path_required": true,
    "exercise_all_touched_functions_when_practical": true,
    "copy_relevant_production_context_to_scratch_when_needed": true,
    "scratch_dir": "C:\\Users\\anise\\code\\.scratch\\Dev-Management",
    "scratch_dir_gitignored": false,
    "scratch_dir_outside_repo": true,
    "claim_rule": "Do not claim behavior from inspection alone when the touched code can be executed."
  },
  "trunk_branch_leaf_governance": {
    "trunk": {
      "areas": [
        "auth",
        "payment",
        "DB schema",
        "migration",
        "runtime policy",
        "security",
        "architecture"
      ],
      "requirements": [
        "human review",
        "strong evidence"
      ]
    },
    "branch": {
      "areas": [
        "service flows",
        "shared modules",
        "API boundaries"
      ],
      "requirements": [
        "Serena impact map",
        "tests"
      ]
    },
    "leaf": {
      "areas": [
        "isolated UI",
        "terminal feature"
      ],
      "requirements": [
        "verification gates"
      ]
    }
  },
  "fallback_rules": {
    "missing_context7": "block_external_library_framework_change_without_explicit_fallback_approval",
    "missing_serena": "block_trunk_or_branch_modification_without_low_risk_leaf_fallback_approval",
    "missing_domain_rag": "block_business_rule_implementation",
    "skills_cannot_replace_evidence": true,
    "fabricated_evidence_forbidden": true,
    "unknown_domain_requirement": "blocked_until_domain_evidence_exists"
  },
  "codex_app_performance_maintenance": {
    "log_retention_days_uncompressed": 1,
    "compress_older_logs": true,
    "scheduled_interval_minutes": 240,
    "run_at_logon": true,
    "max_log_rows": 30000,
    "max_session_files": 60,
    "resource_health_cleanup": "cleanup_stale_serena_every_cycle"
  },
  "scorecard_runtime_hook": {
    "required": true,
    "event": "UserPromptSubmit",
    "required_each_task_turn": true,
    "user_prompt_throttle_seconds": 0,
    "status": "approved_scorecard_user_prompt_hook_only"
  },
  "quality_workflow": {
    "sqa": "process_assurance",
    "qc": "product_defect_detection",
    "vv": "verification_and_validation",
    "valid_quality_gates": [
      "static analysis",
      "dynamic testing",
      "technical review",
      "audit",
      "test documentation"
    ]
  },
  "quality_terms": {
    "think_again_explain_why": "Before asserting status, approval, readiness, or PASS, re-check the declared scope, oracle, evidence, and counterexamples, then explain the reason for the claim.",
    "test": "Limited exploration for counterexamples plus partial evidence of expected behavior.",
    "verification": "Checking whether current artifacts match the declared oracle, scope, and policy.",
    "review": "Adversarial reading that exposes hidden assumptions, missing counterexamples, wrong oracles, and oversimplification.",
    "pass": "No counterexample was found inside the currently declared scope and oracle; it is not universal proof or formal approval.",
    "formal_approval": "Only an explicit user, reviewer, or gate authority can approve; tests, verification output, and PASS language alone do not grant approval."
  },
  "app_settings_pointer": {
    "path": "C:\\Users\\anise\\code\\Dev-Management\\docs\\GLOBAL_AGENT_WORKFLOW.md",
    "exact_text": "Global authority capsule:\n- The user's explicit instruction is the highest project authority inside allowed system/developer constraints.\n- Before work, read and follow:\nC:\\Users\\anise\\code\\Dev-Management\\docs\\GLOBAL_AGENT_WORKFLOW.md\n\n- Codex App is my UI and Windows-native execution control plane. Repo-specific stack and commands come from that repo's AGENTS.md and package scripts.\n\n- Use Serena for codebase exploration, Context7 for external docs, and tests/reports for final claims. If required evidence is missing, report the gap and do not fabricate it.\n\n- Always run the exact code path touched before claiming behavior; exercise all touched functions directly when practical, and use C:\\Users\\anise\\code\\.scratch\\Dev-Management scratch harnesses to copy relevant production context and observe actual behavior.\n- Test means limited counterexample search plus partial evidence; verification means declared oracle/scope/policy match; review means adversarial reading; PASS means no counterexample found within declared scope/oracle, not formal approval.\n"
  },
  "blocked_assertions": {
    "skills_as_authority": true,
    "context7_as_product_domain_source": true,
    "serena_as_external_docs_source": true,
    "domain_logic_without_domain_evidence": true,
