    "langchain": "rag_or_integration_library_when_repo_contract_requires_it",
    "langgraph": "workflow_graph_or_agent_orchestration_library_when_repo_contract_requires_it",
    "mcp": "app_managed_external_tool_context_surface",
    "marketplace_skills": "workflow_modules_not_truth",
