{
  "version": 4,
  "canonical_execution_surface_id": "local-windows-agent",
  "canonical_remote_execution_surface_id": "decommissioned",
  "surfaces": [
    {
      "id": "local-windows-agent",
      "roles": [
        "canonical_execution_surface",
        "app_host",
        "primary_user_control_surface",
        "local_git_surface"
      ],
      "authority": true
    }
  ],
  "required_tool_families": [
    "git",
    "python",
    "node",
    "npm",
    "pwsh"
  ],
  "optional_tool_families": [
    "uv",
    "docker",
    "dotnet",
    "gh"
  ],
  "missing_reason_taxonomy": [
    "not_installed",
    "not_on_path",
    "surface_mismatch",
    "policy_intentional",
    "unconfirmed"
  ],
  "surface_gate_rules": {
    "required_missing_status": "BLOCKED",
    "optional_missing_status": "HOLD",
    "exclude_environment_blocked_runs_from_variant_scoring": true
  },
  "local_vs_remote_mismatch_rules": {
    "canonical_surface_must_match_authority": true,
    "auto_mode_falls_back_to_local_authority": false,
    "status_on_mismatch": "BLOCKED"
  },
  "client_surface_policy": {
    "codex_app_session_path_is_client_surface_only": true,
    "codex_app_session_is_primary_user_control_surface": true,
    "client_surface_contamination_status_when_canonical_passes": "WARN",
    "local_shell_execution_status_when_forbidden_runtime_is_selected": "BLOCKED"
  },
  "forbidden_path_contamination_rules": {
    "blocked_prefixes": [
      "legacy-linux-path",
      "mounted-linux-launcher"
    ],
    "blocked_suffixes": [],
    "front_loaded_arg0_status": "BLOCKED"
  },
  "codex_resolution_precedence_rules": {
    "preferred_primary_resolution": "Windows-native Codex app agent with PowerShell 7",
    "forbidden_primary_resolution": "legacy Linux/remote route or mounted launcher",
    "status_on_forbidden_resolution": "BLOCKED"
  },
  "generated_mirror_rules": {
    "windows_control_plane": "C:\\Users\\anise\\.codex\\config.toml",
    "mirrors_are_outputs_only": true,
    "generated_mirror_self_feed_status": "BLOCKED"
  },
  "windows_policy_surface_rules": {
    "codex_home": "C:\\Users\\anise\\.codex",
    "policy_bearing_relative_paths": [
      "config.toml",
      "AGENTS.md",
      "hooks.json",
      "skills"
    ],
    "unknown_policy_surface_status": "WARN"
  },
  "worktree_policy": {
    "canonical_repo_root": "C:\\Users\\anise\\code\\Dev-Management",
    "persistent_ops_worktree_allowed": false,
    "persistent_ops_worktree_enablement": "explicit_only",
    "persistent_ops_worktree_root": "",
    "persistent_ops_worktree_is_authority": false,
    "task_worktrees_are_ephemeral": true,
    "generated_mirrors_must_use_canonical_repo_root": true,
    "report_identity_fields": [
      "active_worktree_root",
      "canonical_repo_root"
    ],
    "persistent_ops_worktree_allowed_tasks": [
      "recurring_audits",
      "report_generation",
      "readiness_checks",
      "app_usability_checks",
      "non_destructive_diagnostics",
      "automation_without_source_modification_unless_all_gates_pass"
    ],
    "task_worktree_default_for_code_changes": true,
    "stale_persistent_worktree_status": "WARN",
    "branch_checked_out_in_multiple_locations_status": "BLOCKED",
    "worktree_authority_escalation_status": "BLOCKED",
    "cleanup_and_handoff_required": true
  },
  "git_surface_drift_rules": {
    "windows_git_observation_only": false,
    "local_dirty_state_status": "WARN",
    "lfs_missing_status": "WARN",
    "stale_safe_directory_status": "WARN",
    "stale_persistent_worktree_status": "WARN",
    "branch_checked_out_in_multiple_locations_status": "BLOCKED",
    "worktree_authority_escalation_status": "BLOCKED",
    "mixed_windows_and_legacy_linux_execution_status": "BLOCKED"
  },
  "app_surface_rules": {
    "codex_app_role": "primary_user_control_surface",
    "codex_app_remote_session_role": "decommissioned",
    "windows_codex_state_role": "app_state_evidence_only",
    "windows_codex_launcher_role": "external_dependency"
  },
  "release_driven_audit_surfaces": {
    "codex_app_installed_release": true,
    "codex_app_remote_connections": true,
    "codex_app_multiple_terminals": true,
    "codex_app_plugins": true,
    "codex_app_skills": true,
    "codex_app_mcp_plugin_surface": true,
    "codex_app_automations": true,
    "codex_app_worktrees": true,
    "codex_app_projectless_chats": true,
    "codex_app_memories": true,
    "codex_app_local_environments": true,
    "codex_app_integrated_terminal": true,
    "codex_app_settings_sync": true,
    "codex_app_computer_use": true,
    "codex_app_in_app_browser": true
  },
  "evidence_sources": [
    "package.json",
    "pyproject.toml",
    "contracts/project_policy.json",
    "management:docs/RUNBOOK.md",
    "management:docs/USER_DEV_ENVIRONMENT_BASELINE.md",
    "management:docs/GLOBAL_RUNTIME_ARCHITECTURE.md"
  ]
}
