{
  "version": 1,
  "server_name": "context7",
  "transport": "remote_http",
  "remote_template": {
    "url": "https://mcp.context7.com/mcp",
    "enabled": true,
    "required": false,
    "tool_timeout_sec": 30,
    "env_http_headers": {
      "CONTEXT7_API_KEY": "CONTEXT7_API_KEY"
    }
  },
  "override_policy": {
    "transport": "remote_http",
    "allowed_override_keys": [
      "enabled",
      "required",
      "tool_timeout_sec",
      "startup_timeout_sec",
      "enabled_tools",
      "disabled_tools",
      "url",
      "env_http_headers"
    ],
    "forbidden_keys": [
      "bearer_token_env_var",
      "command",
      "args",
      "env",
      "env_vars",
      "cwd"
    ]
  },
  "agent_targets": [
    "/home/andy4917/.codex/AGENTS.md"
  ],
  "protected_change_globs": [
    "package.json",
    "package-lock.json",
    "app_v2/package.json",
    "pyproject.toml",
    "uv.lock",
    "requirements*.txt",
    ".codex/*.toml",
    "config/**",
    "scripts/install_or_repair_toolchain.py",
    "scripts/update_wsl_and_ubuntu.py",
    "scripts/check_context7.py",
    "scripts/bootstrap_real_env.py"
  ],
  "source_candidate_globs": [
    "app_v2/**/*.ts",
    "app_v2/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.ts"
  ],
  "self_config_globs": [
    ".codex/config.toml",
    "scripts/bootstrap_real_env.py"
  ],
  "required_report_fields": [
    "query",
    "resolved_library_id",
    "docs_retrieved",
    "version_evidence",
    "decision_summary"
  ]
}
