{
  "version": 2,
  "scope": "codex-global",
  "summary": "Anti-cheat weighted scorecard policy for Codex global delivery oversight.",
  "principles": {
    "deductions_only": false,
    "writer_self_scoring_forbidden": true,
    "user_bonus_forbidden": false,
    "user_additive_awards": true,
    "user_problem_discovery_resolution_awards": true,
    "user_review_layer_requires_explicit_request_or_approval": true,
    "verified_work_auto_awards_enabled": true,
    "user_midstream_awards_allowed": true,
    "score_is_not_pass": true,
    "disqualifier_outranks_score": true,
    "pass_requires_reviewer_green": true,
    "pass_requires_clean_room_verify": true
  },
  "credit_sources": {
    "creditable": [
      "verified_execution",
      "clean_room_verify",
      "user_approved_review",
      "reviewer_penalty",
      "system_derived"
    ],
    "requested_only": [
      "agent_request"
    ]
  },
  "anti_cheat_layer": {
    "enabled": true,
    "summary": "Maximize confirmed work, but remove or cap credit when score surfaces are manipulated, spoofed, or overstuffed.",
    "reward_function": {
      "objective": "Reward verified outcomes and user-confirmed problem solving, while minimizing unverified self-credit and score-surface manipulation.",
      "effective_total_formula": "guarded_total_score = max(raw_total_score - anti_cheat_penalty_points, 0); capped_total_score = min(guarded_total_score, all active caps)"
    },
    "decision_policy": {
      "auto_dq_codes": [
        "unauthorized_user_review_modification",
        "reserved_derived_award_spoofing",
        "reviewer_truth_tamper",
        "score_policy_tamper_without_policy_update_workorder",
        "protected_path_access_attempt",
        "artifact_hygiene_policy_violation"
      ]
    },
    "penalty_cap": 30,
    "per_axis_user_award_budgets": {
      "completion_score": 6
    },
    "reserved_award_categories": [
      "verified_work",
      "verified_work_execution",
      "system_verified_work",
      "derived_award",
      "system_derived"
    ],
    "signal_rules": [
      {
        "id": "unauthorized_user_review_modification",
        "points": 12,
        "severity": "critical",
        "disqualifier_id": "DQ-011",
        "reason": "Unauthorized writes to the protected user-review layer are treated as score manipulation."
      },
      {
        "id": "reserved_derived_award_spoofing",
        "points": 16,
        "severity": "critical",
        "disqualifier_id": "DQ-011",
        "reason": "Spoofing reserved derived-award categories is treated as reward hacking."
      },
      {
        "id": "non_user_source_award",
        "points": 12,
        "severity": "high",
        "reason": "User awards must originate from the protected user layer only."
      },
      {
        "id": "excessive_bonus_request",
        "points": 8,
        "severity": "medium",
        "reason": "Award requests above the configured budget are partially denied and penalized."
      },
      {
        "id": "reviewer_truth_tamper",
        "points": 18,
        "severity": "critical",
        "disqualifier_id": "DQ-011",
        "reason": "Reviewer-truth tampering is treated as score manipulation."
      },
      {
        "id": "writer_self_score_attempt",
        "points": 18,
        "severity": "critical",
        "reason": "Writer self-awards or self-penalty manipulation are forbidden."
      },
      {
        "id": "claimed_verification_without_evidence",
        "points": 10,
        "severity": "medium",
        "reason": "Verification claims without report or evidence references are treated as unverified score pressure."
      },
      {
        "id": "test_deletion_or_weakening_without_rationale",
        "points": 25,
        "severity": "high",
        "reason": "Deleting tests or adding skip or xfail markers without a written rationale is treated as score-surface manipulation."
      },
      {
        "id": "score_policy_tamper_without_policy_update_workorder",
        "points": 20,
        "severity": "critical",
        "disqualifier_id": "DQ-011",
        "reason": "Changing protected score policy without a policy update workorder is treated as score manipulation."
      },
      {
        "id": "evidence_backdating_or_stale_report_reuse",
        "points": 20,
        "severity": "high",
        "reason": "Reusing stale verification reports or evidence manifests is treated as capped score pressure."
      },
      {
        "id": "waiver_without_reason",
        "points": 8,
        "severity": "medium",
        "reason": "Waivers must include an explicit rationale."
      },
      {
        "id": "gate_order_drift",
        "points": 20,
        "severity": "high",
        "reason": "Delivery gate order must stay aligned with canonical policy."
      },
      {
        "id": "protected_path_access_attempt",
        "points": 40,
        "severity": "critical",
        "disqualifier_id": "DQ-011",
        "reason": "Confirmed writes against protected authority surfaces are treated as score manipulation."
      },
      {
        "id": "verification_command_substitution",
        "points": 20,
        "severity": "high",
        "reason": "Replacing required verification commands with unapproved substitutes is treated as evidence manipulation."
      },
      {
        "id": "evidence_manifest_mismatch",
        "points": 25,
        "severity": "high",
        "reason": "Evidence manifest content must match the recorded policy hashes and run facts."
      },
      {
        "id": "task_skip_or_merge_without_rationale",
        "points": 20,
        "severity": "high",
        "reason": "Skipping or merging task-tree work without rationale is treated as hidden execution drift."
      },
      {
        "id": "unsupported_transition_claim",
        "points": 10,
        "severity": "medium",
        "reason": "Transition language such as therefore or consistent with must not replace linked evidence."
      },
      {
        "id": "verification_word_without_artifact",
        "points": 10,
        "severity": "medium",
        "reason": "Verification language without a fresh command, report, or test artifact is treated as unsupported proof."
      },
      {
        "id": "convention_drift",
        "points": 20,
        "severity": "high",
        "reason": "Replacing canonical authority or score terminology with generic defaults is treated as convention drift."
      },
      {
        "id": "zombie_section_or_stale_claim",
        "points": 20,
        "severity": "high",
        "reason": "Zombie sections, stale claims, or uncovered material claims are treated as report integrity defects."
      },
      {
        "id": "aesthetic_or_report_smoothing",
        "points": 8,
        "severity": "medium",
        "reason": "Hiding waivers, penalties, caps, or disagreements for presentation reasons is treated as report smoothing."
      },
      {
        "id": "cross_verification_disagreement_unresolved",
        "points": 20,
        "severity": "high",
        "reason": "Unresolved independent verifier disagreement must stay visible and cannot silently pass."
      },
      {
        "id": "result_fit_tweaking",
        "points": 20,
        "severity": "high",
        "reason": "Tweaking result language to fit the target outcome without supporting evidence is treated as score pressure."
      },
      {
        "id": "formula_or_code_simplification_without_case_check",
        "points": 10,
        "severity": "medium",
        "reason": "Formula or code simplification without case checks is treated as unsupported correctness pressure."
      },
      {
        "id": "artifact_hygiene_policy_violation",
        "points": 25,
        "severity": "critical",
        "disqualifier_id": "DQ-012",
        "reason": "Retaining backup or temporary artifacts instead of disposing them through the Recycle Bin policy is treated as cleanup-policy evasion."
      }
    ],
    "cap_tiers": [
      {
        "min_points": 8,
        "max_total_score": 89,
        "reason": "Anti-cheat guard reduced the total score because suspicious scoring signals were detected."
      },
      {
        "min_points": 16,
        "max_total_score": 79,
        "reason": "Anti-cheat guard reduced the total score heavily because multiple score-manipulation signals were detected."
      }
    ]
  },
  "axes": {
    "trust_score": {
      "max_points": 30,
      "floor": 24,
      "applicable_when": "always",
      "owner_roles": [
        "skeptic_reviewer",
        "final_auditor",
        "user_review"
      ]
    },
    "completion_score": {
      "max_points": 30,
      "floor": 24,
      "applicable_when": "always",
      "scoring_mode": "verified_work_plus_user_awards",
      "base_points": 0,
      "award_sources": [
        "verified_work",
        "user_review"
      ],
      "derived_awards": [
        {
          "id": "confirmed_work_execution",
          "points": 24,
          "reason": "Reserved completion credit is generated only from clean-room verify PASS or WAIVED evidence.",
          "category": "system_derived",
          "source": "clean_room_verify",
          "when_all": {
            "clean_room_verify_credit_eligible": true
          }
        }
      ],
      "owner_roles": [
        "correctness_verifier",
        "final_auditor",
        "user_review"
      ]
    },
    "compliance_score": {
      "max_points": 20,
      "floor": 16,
      "applicable_when": "always",
      "owner_roles": [
        "skeptic_reviewer",
        "final_auditor",
        "user_review"
      ]
    },
    "reliability_score": {
      "max_points": 10,
      "floor": 7,
      "applicable_when_any": [
        "reliability_applicable",
        "external_calls"
      ],
      "owner_roles": [
        "contamination_monitor",
        "final_auditor",
        "user_review"
      ]
    },
    "search_evidence_score": {
      "max_points": 10,
      "floor": 7,
      "applicable_when_any": [
        "search_evidence_applicable",
        "retrieval_canonical_decision_path",
        "external_docs_dependency",
        "search_engineering_core_path"
      ],
      "owner_roles": [
        "correctness_verifier",
        "final_auditor",
        "user_review"
      ]
    }
  },
  "total_score": {
    "floor": 80
  },
  "review_roles": {
    "skeptic_reviewer": {
      "required_by_default": true,
      "required_unless": [
        "small_l0"
      ]
    },
    "correctness_verifier": {
      "required_when_any": [
        "completion_review_required",
        "search_evidence_applicable",
        "retrieval_canonical_decision_path",
        "external_docs_dependency"
      ]
    },
    "contamination_monitor": {
      "required_when_any": [
        "contamination_review_required",
        "reliability_applicable",
        "external_calls",
        "untrusted_context",
        "web_or_mcp_access",
        "security_sensitive"
      ]
    },
    "final_auditor": {
      "required_by_default": true,
      "required_modes": [
        "verify",
        "release"
      ],
      "required_when_any": [
        "final_auditor_required"
      ]
    }
  },
  "caps": [
    {
      "id": "legacy_hardcoding_violation",
      "target_score_multiplier": 0.7,
      "when_all": {
        "legacy_hardcoding_violation": true
      },
      "reason": "Legacy or hardcoding violations trigger an automatic rebuild or refactor path, so total score is capped at 70% of the target score."
    },
    {
      "id": "retrieval_canonical_decision_path",
      "max_total_score": 85,
      "when_all": {
        "retrieval_canonical_decision_path": true
      },
      "reason": "Retrieval is on the canonical decision path, so total score is capped at 85."
    },
    {
      "id": "external_calls_without_reliability_evidence",
      "max_total_score": 79,
      "when_all": {
        "external_calls": true,
        "reliability_evidence_present": false
      },
      "reason": "External-call work without shared wrapper, timeout, bounded retry, jitter, idempotency, and circuit-breaker evidence is capped at 79."
    },
    {
      "id": "untrusted_context_without_security_evidence",
      "max_total_score": 84,
      "when_all": {
        "untrusted_context": true,
        "security_evidence_present": false
      },
      "reason": "Web, MCP, or untrusted-context work without prompt-injection defense and output-validation evidence is capped at 84."
    }
  ],
  "advisories": [
    {
      "id": "search_engineering_not_core_path",
      "when_all": {
        "search_evidence_applicable": false,
        "search_engineering_core_path": false,
        "retrieval_canonical_decision_path": false
      },
      "message": "Search Engineering is not on the core path, so search evidence remains advisory-only."
    }
  ],
  "gate_order": [
    "disqualifier_check",
    "reviewer_green_check",
    "trace_presence_check",
    "taste_gate_check",
    "task_tree_check",
    "evidence_manifest_check",
    "repeated_verify_check",
    "cross_verification_check",
    "convention_lock_check",
    "summary_coverage_check",
    "axis_floor_check",
    "anti_cheat_guard_check",
    "platform_cap_check",
    "existing_readiness_and_manual_close_out_check",
    "clean_room_verify_check"
  ]
}
