# Dev-Management direnv bootstrap.
# Source of truth is contracts/path_authority_policy.json, not this file.

if [ -f .env ]; then
  dotenv .env
fi

if [ -f .env.local ]; then
  dotenv .env.local
fi

export DEVMGMT_ROOT="${DEVMGMT_ROOT:-$(pwd)}"
export PATH="$HOME/.local/share/dev-management/codex-npm/bin:$PATH"
