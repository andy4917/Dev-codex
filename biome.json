{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "scripts/**/*.js",
      "scripts/**/*.mjs",
      "scripts/**/*.ts",
      "scripts/**/*.tsx",
      "tests/**/*.js",
      "tests/**/*.mjs",
      "tests/**/*.ts",
      "tests/**/*.tsx",
      "!**/.agent-runs",
      "!**/.serena",
      "!.patch-links",
      "!reports",
      "!quarantine"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  }
}
